# Two-host active/passive HA example.
#
# - Node A (primary) at host-a:  compose up with HA_SELF_ID=A, HA_INITIAL_ROLE=primary
# - Node B (standby) at host-b:  compose up with HA_SELF_ID=B, HA_INITIAL_ROLE=standby
#
# Replica storage: any backend Litestream supports (file, s3, sftp, gcs, abs).
# The example below uses s3 (or a MinIO bucket) — easiest to reason about.
# Replace the s3://... URLs with SFTP (e.g. sftp://user@host-b:22/backups/A)
# or file:///mnt/shared/A if you have shared storage between the hosts.
#
# HA_TOKEN is a shared secret for peer-to-peer demotion calls. Generate with:
#   openssl rand -hex 32
#
# On node A:
#   HA_ENABLED=true \
#   HA_SELF_ID=A HA_INITIAL_ROLE=primary \
#   HA_REPLICA_URL_SELF=s3://atlas-replica/A \
#   HA_REPLICA_URL_PEER=s3://atlas-replica/B \
#   HA_PEER_URL=https://host-b:8000 \
#   HA_TOKEN=<shared-secret> \
#   LITESTREAM_ACCESS_KEY_ID=... LITESTREAM_SECRET_ACCESS_KEY=... \
#   docker compose up -d
#
# On node B:
#   HA_ENABLED=true \
#   HA_SELF_ID=B HA_INITIAL_ROLE=standby \
#   HA_REPLICA_URL_SELF=s3://atlas-replica/B \
#   HA_REPLICA_URL_PEER=s3://atlas-replica/A \
#   HA_PEER_URL=https://host-a:8000 \
#   HA_TOKEN=<same-shared-secret> \
#   LITESTREAM_ACCESS_KEY_ID=... LITESTREAM_SECRET_ACCESS_KEY=... \
#   docker compose up -d
#
# To fail over: open https://host-b/  →  a "Standby" screen appears.
# Click "Make me primary". Node B runs litestream restore from A's replica
# slot, flips its role, starts replicating to its own slot, and calls
# POST /api/ha/demote on Node A to take it out of write mode.

services:
  backend:
    environment:
      # Passed through from the invoking shell — see above.
      - LITESTREAM_ACCESS_KEY_ID=${LITESTREAM_ACCESS_KEY_ID:-}
      - LITESTREAM_SECRET_ACCESS_KEY=${LITESTREAM_SECRET_ACCESS_KEY:-}
